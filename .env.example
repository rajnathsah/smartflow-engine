# ─────────────────────────────────────────────────────
#  synq.to — Environment Variables Reference
#  Copy this file to `.env` and fill in real values.
#  Never commit `.env` to version control.
# ─────────────────────────────────────────────────────

# ── Authentication ─────────────────────────────────────
JWT_SECRET_KEY=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── AES-256-GCM Credential Vault ───────────────────────
MASTER_VAULT_KEY=your_32_byte_master_vault_key_here

# ── Email / Invitation Service (n8n Webhook) ───────────
N8N_WEBHOOK_URL=https://aditya546shah.app.n8n.cloud/webhook/user-onboarding
APP_LOGIN_URL=http://localhost:5173/login

# ── Redis (Celery Broker & Result Backend) ─────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Database (Optional external Postgres/MySQL) ─────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/synqto
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=synq_auth_db
POSTGRES_PORT=5432

# ── FastAPI Server ──────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# ── Frontend (Vite) ─────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
